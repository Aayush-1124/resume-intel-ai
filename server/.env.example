# Server port
PORT=5000

# MongoDB connection string
# Option A: SRV format (simpler, requires DNS SRV lookup support)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>
#
# Option B: Standard format (use if your ISP blocks SRV DNS lookups)
# MONGODB_URI=mongodb://<user>:<password>@<shard1>:27017,<shard2>:27017,<shard3>:27017/?ssl=true&replicaSet=<replica>&authSource=admin
MONGODB_URI=

# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# SerpApi API key (for Job Search) — get one at https://serpapi.com (100 free searches/month)
SERPAPI_API_KEY=

# Frontend deployment URL (for CORS)
FRONTEND_URL=
